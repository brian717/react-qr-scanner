# Default: let Git decide if a file is text and normalize line endings to LF in the repo.
* text=auto eol=lf

# Lockfiles and JSON/YAML/Markdown configs: always LF.
package-lock.json text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

# Source files: always LF.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.css text eol=lf
*.html text eol=lf

# Shell scripts must stay LF regardless of platform.
*.sh text eol=lf

# Windows scripts stay CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets: never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.mp3 binary
*.wav binary
*.woff binary
*.woff2 binary
